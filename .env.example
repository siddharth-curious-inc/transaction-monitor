# Copy to `.env` (git-ignored) and fill in the two tokens. config.py auto-loads
# `.env` at repo root, so `python interactivity/app.py` and
# `python src/run.py --dry-run` both pick these up. Real exported env vars still
# win over the file.

# --- secrets: fill these in --------------------------------------------------
# Bot token (xoxb-). Needs scopes: chat:write, reactions:write, *:history.
SLACK_BOT_TOKEN=
# App-level token (xapp-) for Socket Mode. Needs the connections:write scope.
SLACK_APP_TOKEN=

# --- scratch test targets (pre-filled; not secrets) --------------------------
# Scratch workbook (contains the "test - Sid" household tab).
SHEET_ID=18vUCBuKOugji7FSSf-lzN0IF-5oG3-bQuvVMJFKuqtY
# Scratch Slack channel, used for BOTH reading transactions and posting prompts.
OTP_CHANNEL_ID=C0BCY8N6DAA
TRANSACTION_CHANNEL_ID=C0BCY8N6DAA

# --- optional knobs ----------------------------------------------------------
# 1 = print the household-row write instead of performing it (messages still
# update so you can watch the flow). Leave unset to actually write to the sheet.
# DRY_RUN=1
# Leave unset to use Application Default Credentials for Sheets
# (`gcloud auth application-default login`). Set to a key-file path to override.
# GOOGLE_SA_JSON_PATH=
# Poll faster while testing so you don't wait ~75s for a prompt.
# POLL_INTERVAL_SECONDS=15
